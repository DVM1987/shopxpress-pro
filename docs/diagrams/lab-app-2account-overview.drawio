        <!-- ============================================================ -->
        <mxCell id="legend" value="LEGEND&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;━━ solid: traffic active&#xa;┄┄ dashed: standby (chỉ active khi drill)&#xa;━━ blue: primary path&#xa;━━ orange: secondary/DR path&#xa;━━ yellow: image flow&#xa;━━ green: backup flow&#xa;━━ purple: IAM cross-account&#xa;━━ red: audit/log aggregation&#xa;&#xa;Status (2026-05-09):&#xa;✅ Account A Sub-comp 0..9 LIVE&#xa;⏳ Account B chưa deploy&#xa;⏳ Phase 4 (Buổi 16-19) pending" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
