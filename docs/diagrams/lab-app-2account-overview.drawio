        </mxCell>

        <mxCell id="ecr_b" value="ECR replica B&#xa;auto-replicated từ A&#xa;(registry replication rule apse1→apse2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D79B00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="640" width="350" height="70" as="geometry" />
        </mxCell>

        <mxCell id="s3_velero_b" value="S3 bucket Velero target&#xa;cross-account write từ A&#xa;Backup K8s manifest + PVC snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D79B00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1230" y="640" width="370" height="70" as="geometry" />
        </mxCell>

        <mxCell id="iam_b" value="IAM cross-account roles:&#xa;• role-velero-write (trust A: Velero pod ở A)&#xa;• role-ecr-pull (trust A CI/CD)&#xa;• role-restore-admin (trust A team manual drill)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="860" y="730" width="740" height="80" as="geometry" />
        </mxCell>

        <mxCell id="security_b" value="Security Hub member account&#xa;(report finding lên A delegated admin)&#xa;GuardDuty cross-account export&#xa;CloudTrail event ship → A organization trail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D79B00;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
