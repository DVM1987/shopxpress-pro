        <mxCell id="eks_b" value="EKS cluster shopxpress-pro-prd-dr-eks v1.34&#xa;1 MNG t3.medium min=0 max=3 desired=0 (SCALE 0 thường)&#xa;Scale up khi DR drill quarterly: 0→3 node trong ~5 phút" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#D79B00;fontSize=11;dashed=1;" vertex="1" parent="1">
