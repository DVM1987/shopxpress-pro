        </mxCell>

        <mxCell id="cost_b" value="Cost B dự kiến:&#xa;• Khi không drill: ~$0/tháng (cluster scale 0, ECR replica + S3 lưu trữ minimal)&#xa;• Khi drill quarterly (1-2h/lần): ~$1-2 / drill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="860" y="930" width="740" height="80" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- 5 cross-account flows (numbered) -->
        <!-- ============================================================ -->

        <!-- Flow 1: Internet User → R53 -->
        <mxCell id="flow_user_r53" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#000000;" edge="1" parent="1" source="user" target="r53_apex">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow 2: R53 → ALB A (primary) -->
        <mxCell id="flow_r53_alb_a" value="① primary&#xa;HTTPS 100%" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#0066CC;strokeWidth=2;" edge="1" parent="1" source="r53_apex" target="alb_a">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="180" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow 3: R53 → ALB B (secondary failover) -->
        <mxCell id="flow_r53_alb_b" value="② secondary failover&#xa;khi A health check fail&#xa;(Buổi 18)" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#D79B00;strokeWidth=2;dashed=1;" edge="1" parent="1" source="r53_apex" target="alb_b">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1280" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Flow 4: ECR A → ECR B (replication) -->
        <mxCell id="flow_ecr_replication" value="③ ECR replication&#xa;A push → B auto pull&#xa;(Buổi 16)" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#D6B656;strokeWidth=2;" edge="1" parent="1" source="aws_services_a" target="ecr_b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow 5: Velero A → S3 B -->
        <mxCell id="flow_velero" value="④ Velero cross-region&#xa;backup A → S3 B&#xa;(Buổi 17)" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="apps_a" target="s3_velero_b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow 6: A IAM → B IAM (assume role) -->
        <mxCell id="flow_iam" value="⑤ AssumeRole&#xa;A principal → B role&#xa;(Buổi 16)" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#9673A6;strokeWidth=2;" edge="1" parent="1" source="ci_a" target="iam_b">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Flow 7: B → A CloudTrail aggregate -->
        <mxCell id="flow_cloudtrail" value="⑥ CloudTrail org trail&#xa;B event → A aggregate&#xa;(Buổi 19)" style="endArrow=classic;html=1;rounded=0;fontSize=11;strokeColor=#B85450;strokeWidth=2;startArrow=classic;" edge="1" parent="1" source="security_b" target="aws_services_a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
